# FixLink-V1 — Environment Variable Reference
# Copy this file to .env and fill in your values before running the app.
# Never commit the actual .env file to version control.

# ─── Flask ────────────────────────────────────────────────────────────────────
# REQUIRED for production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-hex-string

# ─── Database ─────────────────────────────────────────────────────────────────
# Defaults to SQLite. For Postgres use: postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///vyas_tracker.db

# ─── Default Admin Account ────────────────────────────────────────────────────
# Created automatically on first startup if the email does not already exist.
ADMIN_EMAIL=admin@mitwpu.edu.in
ADMIN_PASSWORD=change-me-strong-password

# ─── EmailJS (transactional email) ────────────────────────────────────────────
# Obtain these from https://www.emailjs.com/
# If left blank, email sending is silently skipped (dev-friendly).
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=True
